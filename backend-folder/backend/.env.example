# =============================================================================
# PulseDrive Backend — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# ⚠️  NEVER commit .env to Git — it contains secrets!
# =============================================================================


# -----------------------------------------------------------------------------
# 🗄️  MongoDB
# -----------------------------------------------------------------------------

# MongoDB Atlas (cloud) — recommended for production:
#   mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
#
# Local MongoDB — for development:
#   mongodb://localhost:27017/
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Name of the database inside MongoDB
DATABASE_NAME=PulseDrive


# -----------------------------------------------------------------------------
# 🔐  Auth / JWT
# -----------------------------------------------------------------------------

# Strong random secret key for signing JWT tokens
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# JWT signing algorithm (leave as HS256 unless you need RS256)
ALGORITHM=HS256

# How long access tokens stay valid (in minutes). Default = 1440 (24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440


# -----------------------------------------------------------------------------
# 🤖  AI / Groq LLM
# -----------------------------------------------------------------------------

# Your Groq API key — get one at https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq API base URL (leave as default unless self-hosting)
GROQ_API_URL=https://api.groq.com/v1

# LLM model to use for AI diagnosis & recommendations
# Options: llama3-8b-8192 | llama3-70b-8192 | mixtral-8x7b-32768 | gemma-7b-it
AI_MODEL=llama3-8b-8192


# -----------------------------------------------------------------------------
# 📞  Service Concierge (Twilio, Sarvam, Maps)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
PUBLIC_BASE_URL=


# -----------------------------------------------------------------------------
# ⚡  Snapdragon NPU / Qualcomm QNN (Edge AI)
# -----------------------------------------------------------------------------

# Set to true to force QNN execution provider even if not auto-detected
# Use on Snapdragon X Elite / 8cx Gen 3 devices with QNN SDK installed
FORCE_QNN=false

# Set to true to simulate QNN runtime on non-Snapdragon hardware (dev/testing)
# Useful for local testing without a physical Snapdragon device
SIMULATE_QNN=false
