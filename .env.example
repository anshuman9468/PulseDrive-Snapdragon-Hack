# PulseDrive Environment Variables
# ==================================
# Copy this file to .env and fill in the values.
# NEVER commit the actual .env to source control.

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# API
API_VERSION=v1

# Model
MODEL_PATH=backend/models/optimized/pulsedrive.onnx
MODEL_LABELS_PATH=backend/models/labels.json

# Sarvam AI (GenAI Multilingual)
SARVAM_API_KEY=your-sarvam-api-key-here
SARVAM_BASE_URL=https://api.sarvam.ai

# Qualcomm AI Hub
QAI_HUB_API_KEY=your-qualcomm-ai-hub-api-key-here
QAI_HUB_DEVICE=Snapdragon 8 Elite
